# wlime configuration
# Copy to ~/.config/wlime/config

# Language / input method
# Supported: pinyin, korean, japanese, rime:<schema>
# RIME schemas (requires librime + schema data):
#   rime:luna_pinyin      — Mandarin pinyin
#   rime:luna_pinyin_simp — Simplified Chinese pinyin
#   rime:jyut6ping3       — Cantonese jyutping
#   rime:bopomofo         — Bopomofo/Zhuyin
#   rime:cangjie5         — Cangjie
# Install additional schemas for more languages.
language = pinyin

# Always copy committed text to clipboard (true/false)
clipboard_always = true

# Sound effects (true/false)
sounds = true

# Custom sound directory (default: ~/.config/wlime/sounds)
# sound_dir = /path/to/sounds

# Fade animation (true/false)
animate = true

# Fade duration in milliseconds
fade_duration_ms = 150
